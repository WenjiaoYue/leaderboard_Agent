# Copy this file to .env, fill MINIMAX_API_KEY, then run ./run.sh

IMAGE_NAME=cuda-openclaw:local
CONTAINER_NAME=cuda-openclaw-new

# ── Required: fill your MiniMax API key ───────────────────────────────────────
MINIMAX_API_KEY=<your-minimax-api-key>
# ── Auto-Quant / Auto-Eval defaults ──────────────────────────────────────────
MODEL_ID=Qwen/Qwen3-0.6B
SCHEME=W4A16
METHOD=RTN
EXPORT_FORMAT=auto_round:auto_gptq
DEVICE=cuda
DEVICE_INDEX=0
OUTPUT_DIR=/root/.openclaw/workspace/quantized
TIMEOUT=7200

# ── Proxy (if behind corporate proxy, otherwise leave empty) ─────────────────
HTTP_PROXY=
HTTPS_PROXY=
