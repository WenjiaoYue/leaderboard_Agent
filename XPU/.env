# Copy this file to .env, fill MINIMAX_API_KEY, then run ./run.sh

IMAGE_NAME=xpu-openclaw:local
CONTAINER_NAME=xpu-openclaw-test5

# ── Required: fill your MiniMax API key ───────────────────────────────────────
MINIMAX_API_KEY=sk-cp-vw8CpW4W9UOCfz8qU6ydO9lmU_C3Ff_C-7qcxv_qnyv_2xg3OJHFJPvID93oJBuvtqeUisNVZmCZ6rH11YfLn4Ieqs61NBGohRAkdFmWQ0OokNfSCxzAHXc

# ── Auto-Quant / Auto-Eval defaults ──────────────────────────────────────────
MODEL_ID=Qwen/Qwen3-0.6B
SCHEME=W4A16
METHOD=RTN
EXPORT_FORMAT=auto_round:auto_gptq
DEVICE=xpu
DEVICE_INDEX=0
OUTPUT_DIR=/root/.openclaw/workspace/quantized
TIMEOUT=7200

# ── Intel proxy ──────────────────────────────────────────────────────────────
HTTP_PROXY=http://proxy.ims.intel.com:911
HTTPS_PROXY=http://proxy.ims.intel.com:911
