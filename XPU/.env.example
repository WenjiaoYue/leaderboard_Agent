# Copy this file to .env, fill MINIMAX_API_KEY, then run ./run.sh

IMAGE_NAME=xpu-openclaw:local
CONTAINER_NAME=xpu-openclaw-new

# ── Required: fill your MiniMax API key ───────────────────────────────────────
MINIMAX_API_KEY=<your-minimax-api-key>

# ── Intel proxy ──────────────────────────────────────────────────────────────
HTTP_PROXY=http://proxy.ims.intel.com:911
HTTPS_PROXY=http://proxy.ims.intel.com:911
